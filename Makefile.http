CXX = g++
CXXFLAGS = -std=c++23 -Wall -Wextra -g -I.

# Source files
HTTP_IMPL = kernel/net/http.cc
MOCK_SOCKET = kernel/test/mock_socket.cc
TEST_MAIN = kernel/test/http_test.cc

# Default target
all: test

# Build and run the test
test: http_test
	@echo "Running HTTP tests..."
	@./http_test

# Compile the test program
http_test: $(HTTP_IMPL) $(MOCK_SOCKET) $(TEST_MAIN)
	$(CXX) $(CXXFLAGS) -o $@ $^
	@echo "✓ Compiled http_test"

# Clean up
clean:
	rm -f http_test

.PHONY: all test clean
